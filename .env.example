# Copy to .env and fill in local secrets. .env is gitignored.

FOUNDRY_PROJECT_ENDPOINT=https://tomaskubica-foundry-resource.services.ai.azure.com/api/projects/tomaskubica-foundry-project
FOUNDRY_MODEL=gpt-5.4
FOUNDRY_USE_ENTRA=true

# Volitelné vyhledávací zdroje. Preferovaný režim je hostované Foundry Web Search.
BRAVE_API_KEY=
TAVILY_API_KEY=
NEWSAPI_API_KEY=
MEDIASTACK_API_KEY=
SEARCH_PROVIDER=auto

# Volitelné Foundry Web Search / Grounding with Bing.
# hosted používá hostovaný Foundry WebSearchTool. bing-grounding/custom vyžadují Bing prostředek.
BING_WEB_SEARCH_ENABLED=false
FOUNDRY_WEB_SEARCH_MODE=hosted
BING_PROJECT_CONNECTION_NAME=tomaskubica-bing-grounding
BING_CUSTOM_SEARCH_PROJECT_CONNECTION_ID=
BING_CUSTOM_SEARCH_INSTANCE_NAME=

MAX_SEARCH_RESULTS=10
MAX_WEB_RESULTS=100
MAX_NEWS_RESULTS=100
MAX_CRAWL_PAGES=35
MAX_FOLLOWUP_PAGES=20
MAX_DOCUMENTS=8
MAX_PDF_PAGES=12
MAX_PAGE_CHARS=20000
ENABLE_STOCK_LOOKUP=true
# Mapa oddělená čárkami. Klíče mohou být IČO nebo normalizované názvy; hodnoty jsou Yahoo Finance symboly.
STOCK_SYMBOL_OVERRIDES=45274649=CEZ.PR
# Mapa oddělená čárkami pro odhady tržní hodnoty.
STOCK_SHARES_OUTSTANDING_OVERRIDES=45274649=537989759
REPORT_TEMPLATE_PATH=templates/company_report.md
ENABLE_BROWSER_CRAWLER=false
